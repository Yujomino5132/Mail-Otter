{
  // "$version": 1778244052,
  // "$minimumVersion": 1778244052,
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mail-otter",
  "main": "apps/api/src/index.ts",
  "compatibility_date": "2025-11-29",
  "compatibility_flags": [],
  "preview_urls": false,
  "workers_dev": false,
  "minify": true,
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": true,
      "persist": true,
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "routes": [],
  "placement": {
    "mode": "off",
  },
  "assets": {
    "directory": "./apps/web/dist/",
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CRON_TASKS",
        "class_name": "CronTasksWorker",
      },
      {
        "name": "OAUTH2_TOKEN_REFRESHERS",
        "class_name": "OAuth2TokenRefreshWorker",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1778260000",
      "new_sqlite_classes": ["CronTasksWorker", "OAuth2TokenRefreshWorker"],
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "database_name": "mail-otter-db",
    },
  ],
  "ai": {
    "binding": "AI",
  },
  "vectorize": [
    {
      "binding": "EMAIL_CONTEXT_INDEX",
      "index_name": "mail-otter-email-context",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "OAUTH2_TOKEN_CACHE",
      "id": "00000000000000000000000000000000",
      // "kv_name": "mail-otter-oauth2-token-cache",
    },
  ],
  "workflows": [
    {
      "binding": "EMAIL_PROCESSING_WORKFLOW",
      "name": "mail-otter-email-processing",
      "class_name": "EmailProcessingWorkflow",
    },
  ],
  "queues": {
    "producers": [
      {
        "queue": "mail-otter-email-events",
        "binding": "EMAIL_EVENTS_QUEUE",
      },
    ],
    "consumers": [
      {
        "queue": "mail-otter-email-events",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 5,
      },
    ],
  },
  "triggers": {
    "crons": ["*/10 * * * *"],
  },
  "secrets_store_secrets": [
    {
      "binding": "AES_ENCRYPTION_KEY_SECRET",
      "store_id": "00000000000000000000000000000000",
      "secret_name": "mail-otter-aes-encryption-key",
    },
  ],
  "vars": {
    "SERVE_SPA_FROM_WORKER": "false",
    "POLICY_AUD": "you-cloudflare-zero-trust-application-aud",
    "TEAM_DOMAIN": "https://your-cloudflare-zero-trust-team-domain.cloudflareaccess.com",
    "MAX_APPLICATIONS_PER_USER": "99",
    "OAUTH2_STATE_EXPIRY_MINUTES": "15",
    "AI_SUMMARY_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "AI_EMBEDDING_MODEL": "@cf/baai/bge-base-en-v1.5",
    "MAX_EMAIL_BODY_CHARS": "12000",
    "MAX_CONTEXT_MEMORY_CHARS": "1800",
    "MAX_RAG_CONTEXT_CHARS": "6000",
    "RAG_TOP_K": "5",
    "RAG_VECTOR_QUERY_TOP_K": "50",
    "GMAIL_WATCH_RENEWAL_WINDOW_HOURS": "48",
    "OUTLOOK_SUBSCRIPTION_RENEWAL_WINDOW_HOURS": "24",
    "OUTLOOK_SUBSCRIPTION_TTL_DAYS": "6",
    "OAUTH2_ACCESS_TOKEN_REFRESH_WINDOW_SECONDS": "900",
    "OAUTH2_ACCESS_TOKEN_MIN_VALID_SECONDS": "60",
    "OAUTH2_ACCESS_TOKEN_FALLBACK_TTL_SECONDS": "3600",
    "OAUTH2_TOKEN_REFRESH_BATCH_SIZE": "25",
  },
}
