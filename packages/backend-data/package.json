{
  "name": "@mail-otter/backend-data",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants/index.ts",
    "./constants/*": "./src/constants/*.ts",
    "./crypto": "./src/crypto/index.ts",
    "./crypto/*": "./src/crypto/*.ts",
    "./dao": "./src/dao/index.ts",
    "./dao/*": "./src/dao/*.ts",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mail-otter/backend-errors": "workspace:*",
    "@mail-otter/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "typescript": "6.0.3"
  }
}
