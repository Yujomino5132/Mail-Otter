{
  "name": "@mail-otter/backend-services",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./action": "./src/action/index.ts",
    "./action/*": "./src/action/*.ts",
    "./auth": "./src/auth/index.ts",
    "./auth/*": "./src/auth/*.ts",
    "./application": "./src/application/index.ts",
    "./application/*": "./src/application/*.ts",
    "./email": "./src/email/index.ts",
    "./email/*": "./src/email/*.ts",
    "./oauth2": "./src/oauth2/index.ts",
    "./oauth2/*": "./src/oauth2/*.ts",
    "./subscription": "./src/subscription/index.ts",
    "./subscription/*": "./src/subscription/*.ts",
    "./user": "./src/user/index.ts",
    "./user/*": "./src/user/*.ts",
    "./webhook": "./src/webhook/index.ts",
    "./webhook/*": "./src/webhook/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mail-otter/backend-data": "workspace:*",
    "@mail-otter/backend-errors": "workspace:*",
    "@mail-otter/backend-runtime": "workspace:*",
    "@mail-otter/provider-clients": "workspace:*",
    "@mail-otter/shared": "workspace:*",
    "jose": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "25.9.x",
    "typescript": "^6.0.3"
  }
}
