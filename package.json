{
  "name": "@mail-otter/monorepo",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/ensure-spa-shell-stub.mjs && pnpm run typegen",
    "build": "pnpm -r build",
    "prettier": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config test/integration/vitest.config.mts",
    "test:coverage:integration": "vitest run --coverage --config test/integration/vitest.config.mts",
    "lint": "eslint --ext .ts,.tsx --fix --quiet .",
    "typegen": "wrangler types --config ./apps/api/wrangler.template.jsonc --env-interface CloudflareEnv"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.19",
    "@mail-otter/backend-services": "workspace:*",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-unicorn": "69.0.0",
    "globals": "17.7.0",
    "jsonc-parser": "3.3.1",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "terser": "5.48.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "wrangler": "4.104.0"
  },
  "packageManager": "pnpm@11.2.2"
}
