{
  "name": "@mail-otter/monorepo",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/ensure-spa-shell-stub.mjs",
    "build": "pnpm -r build",
    "dev": "pnpm --filter @mail-otter/web dev",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "prettier": "prettier --write .",
    "lint": "eslint --ext .ts,.tsx --fix .",
    "deploy": "pnpm run build && wrangler deploy --dry-run && wrangler deploy",
    "cf-typegen": "wrangler types --config ./apps/api/wrangler.template.jsonc --env-interface CloudflareEnv ./apps/api/cloudflare-env.d.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1",
    "@types/node": "25.6.x",
    "@types/react": "^19.2.x",
    "@types/react-dom": "^19.2.x",
    "@vitejs/plugin-react": "^6.0.x",
    "eslint": "^10.2.x",
    "eslint-config-prettier": "^10.1.x",
    "eslint-plugin-prettier": "^5.5.x",
    "globals": "^17.5.x",
    "jsonc-parser": "^3.3.x",
    "prettier": "^3.8.x",
    "tailwindcss": "^4.2.x",
    "terser": "^5.46.x",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.x",
    "vite": "^8.0.x",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  },
  "packageManager": "pnpm@10.12.4"
}
