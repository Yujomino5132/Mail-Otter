{
  "name": "@mail-otter/monorepo",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/ensure-spa-shell-stub.mjs && pnpm run typegen",
    "build": "pnpm -r build",
    "checks": "pnpm -r typecheck && pnpm run lint && pnpm run test",
    "prettier": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "lint": "eslint --ext .ts,.tsx --fix .",
    "typegen": "wrangler types --config ./apps/api/wrangler.template.jsonc --env-interface CloudflareEnv"
  },
  "devDependencies": {
    "@types/node": "25.9.x",
    "@types/react": "^19.2.x",
    "@types/react-dom": "^19.2.x",
    "@vitejs/plugin-react": "^6.0.x",
    "eslint": "^10.4.x",
    "eslint-config-prettier": "^10.1.x",
    "eslint-plugin-prettier": "^5.5.x",
    "globals": "^17.6.x",
    "jsonc-parser": "^3.3.x",
    "prettier": "^3.8.x",
    "tailwindcss": "^4.3.x",
    "terser": "^5.48.x",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.x",
    "vite": "^8.0.x",
    "vitest": "^4.1.7",
    "wrangler": "^4.93.1"
  },
  "packageManager": "pnpm@11.2.2"
}
